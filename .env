
#  TikTok Trends — Configurações

# Intervalo de coleta automática (em horas)
COLLECTION_INTERVAL_HOURS=0

# Caminho do banco de dados SQLite
DATABASE_PATH=data/trends.db

# Caminho do arquivo de log
LOG_PATH=logs/app.log

# Nível de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Máximo de hashtags monitoradas simultaneamente
MAX_HASHTAGS=100

# Timeout das requisições HTTP (segundos)
REQUEST_TIMEOUT=15

# Delay entre requisições para não sobrecarregar o TikTok (segundos)
REQUEST_DELAY=2